// webpack.extension.config.js
// Builds offscreen.js (which imports webeyetrack) into a self-contained bundle
// suitable for use inside a Chrome extension's offscreen document.

const path = require('path');

module.exports = {
  mode: 'production',
  entry: './offscreen.src.js',   // rename your offscreen.js to offscreen.src.js before bundling
  resolve: {
    extensions: ['.ts', '.js'],
    fallback: {
      os: false,
      fs: false,
      path: false,
    }
  },
  module: {
    rules: [
      { test: /\.ts$/, loader: 'ts-loader' },
    ],
  },
  output: {
    filename: 'offscreen.js',
    path: path.resolve(__dirname, '.'),   // outputs right into extension root
    globalObject: "typeof self !== 'undefined' ? self : this",
  },
};